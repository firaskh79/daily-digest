<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.firas.daily-digest-push</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd /Users/firaskhnaisser/Documents/daily-digest &amp;&amp; git add -A &amp;&amp; git diff --cached --quiet || git commit -m "Digest $(date +%Y-%m-%d)" &amp;&amp; git push</string>
    </array>

    <key>WatchPaths</key>
    <array>
        <string>/Users/firaskhnaisser/Documents/daily-digest/daily-digest.html</string>
    </array>

    <key>StandardOutPath</key>
    <string>/Users/firaskhnaisser/Documents/daily-digest/push.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/firaskhnaisser/Documents/daily-digest/push.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
